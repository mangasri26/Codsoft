import string
import random
from tkinter import *
from tkinter import messagebox
import sqlite3
with sqlite3.connect("users.db") as db:
    cursor = db.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS users(
            Username TEXT NOT NULL,
            GeneratedPassword TEXT NOT NULL
        );
    """)
    db.commit()
class GUI():
    def __init__(self, master):
        self.master = master
        master.title("Password Generator")
        master.geometry("660x500")
        master.config(bg="#FFDEE9")   # Soft Pink Background
        master.resizable(False, False)
        self.n_username = StringVar()
        self.n_passwordlen = StringVar()
        self.n_generatedpassword = StringVar()

        Label(master, text=": PASSWORD GENERATOR :",
              fg="#C71585", bg="#FFDEE9",
              font=("Georgia", 22, "bold")).grid(row=0, column=1, pady=20)

        Label(master, text="Enter User Name:",
              font=("Georgia", 15, "bold"),
              bg="#FFDEE9", fg="#8B008B").grid(row=4, column=0, padx=10, pady=10)

        self.textfield = Entry(master, textvariable=self.n_username,
                               font=("Calibri", 15),
                               bd=4, relief="ridge")
        self.textfield.grid(row=4, column=1)

        Label(master, text="Enter Password Length:",
              font=("Georgia", 15, "bold"),
              bg="#FFDEE9", fg="#8B008B").grid(row=6, column=0, padx=10, pady=10)

        self.length_textfield = Entry(master,
                                      textvariable=self.n_passwordlen,
                                      font=("Calibri", 15),
                                      bd=4, relief="ridge")
        self.length_textfield.grid(row=6, column=1)

        Label(master, text="Generated Password:",
              font=("Georgia", 15, "bold"),
              bg="#FFDEE9", fg="#8B008B").grid(row=8, column=0, padx=10, pady=10)

        self.generated_password_textfield = Entry(master,
                                                  textvariable=self.n_generatedpassword,
                                                  font=("Courier", 16, "bold"),
                                                  bd=4, relief="ridge",
                                                  fg="#DC143C")
        self.generated_password_textfield.grid(row=8, column=1)

        Button(master, text="GENERATE PASSWORD",
               font=("Verdana", 14, "bold"),
               fg="white", bg="#FF69B4",
               command=self.generate_pass).grid(row=11, column=1, pady=10)

        Button(master, text="ACCEPT",
               font=("Verdana", 14, "bold"),
               fg="white", bg="#32CD32",
               command=self.accept_fields).grid(row=13, column=1, pady=10)

        Button(master, text="RESET",
               font=("Verdana", 14, "bold"),
               fg="white", bg="#FF4500",
               command=self.reset_fields).grid(row=15, column=1, pady=10)

    def generate_pass(self):

        name = self.n_username.get()
        leng = self.n_passwordlen.get()

        if name == "":
            messagebox.showerror("Error", "Name cannot be empty")
            return

        if not name.isalpha():
            messagebox.showerror("Error", "Name must contain only letters")
            return

        if leng == "":
            messagebox.showerror("Error", "Password length required")
            return

        if not leng.isdigit():
            messagebox.showerror("Error", "Password length must be numeric")
            return

        length = int(leng)

        if length < 6:
            messagebox.showerror("Error", "Password must be at least 6 characters")
            return

        upper = string.ascii_uppercase
        lower = string.ascii_lowercase
        digits = string.digits
        symbols = string.punctuation

        all_chars = upper + lower + digits + symbols

        password = [
            random.choice(upper),
            random.choice(lower),
            random.choice(digits),
            random.choice(symbols)
        ]

        password += random.choices(all_chars, k=length - 4)
        random.shuffle(password)

        self.n_generatedpassword.set("".join(password))
    def accept_fields(self):

        username = self.n_username.get()
        password = self.n_generatedpassword.get()

        if username == "" or password == "":
            messagebox.showerror("Error", "Generate password first")
            return

        with sqlite3.connect("users.db") as db:
            cursor = db.cursor()

            cursor.execute("SELECT * FROM users WHERE Username = ?", (username,))
            if cursor.fetchone():
                messagebox.showerror("Error", "Username already exists")
                return

            cursor.execute(
                "INSERT INTO users (Username, GeneratedPassword) VALUES (?, ?)",
                (username, password)
            )
            db.commit()

        messagebox.showinfo("Success", "Password saved successfully")
    def reset_fields(self):
        self.n_username.set("")
        self.n_passwordlen.set("")
        self.n_generatedpassword.set("")
if __name__ == "__main__":
    root = Tk()
    app = GUI(root)
    root.mainloop()
